{
	"globals": {
		"EMOJIS": true,
		"PRODUCTION": true,
		"SCOPE_VERSION": true,
		"TRANSLATIONS": true,
		"oc_userconfig": true,
		"appName": true,
		"appVersion": true
	},
	"ignorePatterns": ["!.storybook/", "coverage", "dist", "node_modules"],
	"extends": [
		"@nextcloud/eslint-config/typescript",
		"plugin:storybook/recommended",
		"plugin:storybook/recommended"
	],
	"plugins": ["cypress"],
	"parserOptions": {
		"babelOptions": {
			"plugins": ["@babel/plugin-syntax-import-assertions"]
		}
	},
	"rules": {
		"@nextcloud/no-deprecations": [
			"error",
			{
				"parseAppInfo": false
			}
		],
		"@nextcloud/no-removed-apis": [
			"error",
			{
				"parseAppInfo": false
			}
		],
		"import/no-unresolved": [
			"error",
			{
				"ignore": ["\\?raw$"]
			}
		]
	}
}
